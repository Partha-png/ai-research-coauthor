# Copy this file to .env and fill in your values
# NEVER commit .env to GitHub!

# ── AWS Credentials ─────────────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=your_access_key_here
AWS_SECRET_ACCESS_KEY=your_secret_key_here
AWS_DEFAULT_REGION=us-east-1

# ── Storage (create these in AWS Console first) ───────────────────────────────
S3_BUCKET_NAME=ai-research-coauthor-mvp
DYNAMODB_TABLE_NAME=research_sessions

# ── Bedrock Model IDs (no change needed) ─────────────────────────────────────
BEDROCK_LLM_MODEL=anthropic.claude-3-5-sonnet-20241022-v2:0
BEDROCK_EMBED_MODEL=amazon.titan-embed-text-v1

# ── Pipeline Tuning ───────────────────────────────────────────────────────────
MAX_PAPERS=10               # papers to retrieve per session (5-20)
MAX_TOKENS_SUMMARY=800      # tokens per paper summary
MAX_TOKENS_SECTION=2500     # tokens per paper section (intro, methodology...)
LLM_TEMPERATURE=0.2         # lower = more focused/factual

# ── Demo / Local Mode (no AWS needed) ────────────────────────────────────────
# Set USE_MOCK_LLM=true to run without AWS credentials (returns placeholder text)
USE_MOCK_LLM=false
